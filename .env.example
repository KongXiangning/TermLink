# TermLink Server Configuration
# Copy this file to .env and modify as needed.

# ── Server ──────────────────────────────────────────────
PORT=3000

# ── Authentication ──────────────────────────────────────
# Auth is ON by default. Set to false only for trusted-network local dev.
AUTH_ENABLED=true
AUTH_USER=admin
AUTH_PASS=CHANGE_ME_TO_STRONG_PASSWORD

# ── Privilege Mode ─────────────────────────────────────
# Server privilege mode: 'standard' (default) or 'elevated'
# Elevated mode requires TERMLINK_ELEVATED_ENABLE=true and non-default credentials
TERMLINK_PRIVILEGE_MODE=standard
TERMLINK_ELEVATED_ENABLE=false

# mTLS requirement for elevated mode (optional)
# TERMLINK_ELEVATED_REQUIRE_MTLS=true
# TERMLINK_MTLS_ENABLED=true

# Audit log path for elevated mode sessions (NDJSON format)
TERMLINK_ELEVATED_AUDIT_PATH=./logs/elevated-audit.log

# IP whitelist for elevated mode (comma-separated, supports CIDR)
# Empty means allow all IPs
TERMLINK_ELEVATED_ALLOWED_IPS=

# ── Session Persistence ─────────────────────────────────
SESSION_PERSIST_ENABLED=true
SESSION_PERSIST_PATH=./data/sessions.json

# ── Session Lifecycle / Retention ──────────────────────
# Keep idle sessions for 6 hours by default.
SESSION_IDLE_TTL_MS=21600000
# Hard limit for in-memory sessions; when full, evict oldest IDLE first.
SESSION_MAX_COUNT=50
# Background cleanup interval.
SESSION_CLEANUP_INTERVAL_MS=60000

# ── PTY / Shell ─────────────────────────────────────────
# Highest priority – override for any OS:
# PTY_SHELL=pwsh.exe

# Windows-only override (ignored on Linux):
# PTY_WINDOWS_SHELL=pwsh.exe

# Linux/WSL-only override (ignored on Windows):
# PTY_UNIX_SHELL=/usr/bin/zsh

# Extra arguments passed to shell (space-separated):
# PTY_SHELL_ARGS=-l
