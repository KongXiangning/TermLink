# TermLink Server Configuration
# Copy this file to .env and modify as needed.

# ── Server ──────────────────────────────────────────────
PORT=3010

# ── Authentication ──────────────────────────────────────
# Auth is ON by default. Set to false only for trusted-network local dev.
AUTH_ENABLED=true
AUTH_USER=admin
AUTH_PASS=admin

# ── Privilege Mode ─────────────────────────────────────
# Server privilege mode: 'standard' (default) or 'elevated'
# Elevated mode requires TERMLINK_ELEVATED_ENABLE=true and non-default credentials
TERMLINK_PRIVILEGE_MODE=standard
TERMLINK_ELEVATED_ENABLE=false

# mTLS requirement for elevated mode (optional)
# TERMLINK_ELEVATED_REQUIRE_MTLS=true

# Audit log path for elevated mode sessions (NDJSON format)
TERMLINK_ELEVATED_AUDIT_PATH=./logs/elevated-audit.log

# IP whitelist for elevated mode (comma-separated, supports CIDR)
# Empty means allow all IPs
TERMLINK_ELEVATED_ALLOWED_IPS=

# ── Session Persistence ─────────────────────────────────
SESSION_PERSIST_ENABLED=true
SESSION_PERSIST_PATH=./data/sessions.json

# ── Session Lifecycle / Retention ──────────────────────
# Keep idle sessions for 6 hours by default.
SESSION_IDLE_TTL_MS=86400000
# Hard limit for in-memory sessions; when full, evict oldest IDLE first.
SESSION_MAX_COUNT=50
# Background cleanup interval.
SESSION_CLEANUP_INTERVAL_MS=60000

# ── PTY / Shell ─────────────────────────────────────────
# Highest priority – override for any OS:
# PTY_SHELL=pwsh.exe

# Windows-only override (ignored on Linux):
# PTY_WINDOWS_SHELL=pwsh.exe

# Linux/WSL-only override (ignored on Windows):
# PTY_UNIX_SHELL=/usr/bin/zsh

# Extra arguments passed to shell (space-separated):
# PTY_SHELL_ARGS=-l

# ── TLS / mTLS ──────────────────────────────────────────
# Enable HTTPS listener. When false (default), server listens on plain HTTP.
# TERMLINK_TLS_ENABLED=true

# Path to server certificate (PEM format)
# TERMLINK_TLS_CERT=./certs/server.crt

# Path to server private key (PEM format)
# TERMLINK_TLS_KEY=./certs/server.key

# Optional passphrase for the server private key
# TERMLINK_TLS_PASSPHRASE=

# Path to trusted client CA bundle (PEM format) for mTLS client verification.
# Only needed when TERMLINK_TLS_CLIENT_CERT is 'require' or 'request'.
# TERMLINK_TLS_CA=./certs/client-ca.crt

# Client certificate policy:
#   'none'    – do not request client certificates (default)
#   'request' – request but do not require (optional mTLS)
#   'require' – require a valid client certificate (strict mTLS)
# TERMLINK_TLS_CLIENT_CERT=none

# Trusted proxy TLS summary mode:
#   'off'   – only trust Node's direct TLS socket state (default)
#   'nginx' – trust explicit Nginx-forwarded TLS/mTLS headers when proxy secret matches
# TERMLINK_TLS_PROXY_MODE=off

# Shared secret required when TERMLINK_TLS_PROXY_MODE is enabled.
# Nginx must forward the same value in X-TermLink-Proxy-Tls-Secret.
# TERMLINK_TLS_PROXY_SECRET=replace-with-long-random-string
