#!/bin/sh

set -e

# --- 1. Sensitive information scan ---
if command -v pwsh >/dev/null 2>&1; then
  PWSH="pwsh"
else
  PWSH="powershell"
fi

$PWSH -NoProfile -ExecutionPolicy Bypass -File "./scripts/git-sensitive-scan.ps1" -Staged

# --- 2. Auto-rebuild CR INDEX when CR records are staged ---
CR_CHANGED=$(git diff --cached --name-only -- 'docs/changes/records/CR-*.md' 2>/dev/null || true)
if [ -n "$CR_CHANGED" ]; then
  echo "[pre-commit] CR records changed — rebuilding INDEX.md ..."
  $PWSH -NoProfile -ExecutionPolicy Bypass -File "./scripts/generate-cr-index.ps1"
  git add docs/changes/records/INDEX.md
  echo "[pre-commit] INDEX.md rebuilt and staged."
fi
