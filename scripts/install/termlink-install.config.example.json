{
  "schemaVersion": 2,
  "installDir": "/opt/termlink",
  "configDir": "/etc/termlink",
  "dataDir": "/var/lib/termlink",
  "runUser": "termlink-user",
  "serviceName": "termlink",
  "autoStart": true,
  "port": 3010,
  "bindAddress": "127.0.0.1",
  "publicHost": "termlink.example.com",
  "auth": {
    "enabled": true,
    "user": "admin",
    "pass": "replace-with-a-strong-password"
  },
  "privilege": {
    "mode": "standard",
    "elevatedEnable": false
  },
  "tls": {
    "mode": "off",
    "clientCertPolicy": "none",
    "certDir": "/etc/termlink/certs",
    "serverCert": "/etc/termlink/certs/server.crt",
    "serverKey": "/etc/termlink/certs/server.key",
    "caCert": "/etc/termlink/certs/client-ca.crt",
    "proxySecret": "replace-with-a-random-proxy-secret",
    "serverSource": "generate",
    "importCert": "",
    "importKey": ""
  },
  "mtls": {
    "deployment": "none",
    "generateDirectServerCertificates": false,
    "generateServerCertificates": false,
    "opensslPath": "openssl",
    "serverOutputDir": "/etc/termlink/certs",
    "clientOutputDir": "/etc/termlink/certs/clients",
    "clientName": "client",
    "clientP12Password": ""
  },
  "nginx": {
    "listenPort": 443,
    "configPath": "/etc/nginx/conf.d/termlink.conf"
  }
}
