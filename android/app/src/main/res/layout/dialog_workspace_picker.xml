<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/workspace_picker_path_label"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/workspace_picker_current_path"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#D0D0D0"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/workspace_picker_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="12sp"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/workspace_picker_progress"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:visibility="gone" />

    <ListView
        android:id="@+id/workspace_picker_list"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_marginTop="8dp"
        android:divider="?android:attr/dividerHorizontal"
        android:dividerHeight="1dp" />
</LinearLayout>
