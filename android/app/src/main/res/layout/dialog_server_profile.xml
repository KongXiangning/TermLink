<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_settings_dialog_surface"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            style="@style/TextAppearance.TermLink.Settings.Label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_profile_name_label" />

        <EditText
            android:id="@+id/input_profile_name"
            style="@style/Widget.TermLink.Settings.EditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/settings_profile_name_hint"
            android:inputType="textCapWords|text" />

        <TextView
            style="@style/TextAppearance.TermLink.Settings.Label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/settings_profile_url_label" />

        <EditText
            android:id="@+id/input_profile_base_url"
            style="@style/Widget.TermLink.Settings.EditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/settings_profile_url_hint"
            android:inputType="textUri" />

        <TextView
            style="@style/TextAppearance.TermLink.Settings.Label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/settings_profile_terminal_type_label" />

        <Spinner
            android:id="@+id/spinner_profile_terminal_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            style="@style/TextAppearance.TermLink.Settings.Label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/settings_profile_auth_type_label" />

        <Spinner
            android:id="@+id/spinner_profile_auth_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:id="@+id/basic_auth_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                style="@style/TextAppearance.TermLink.Settings.Label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/settings_profile_basic_username_label" />

            <EditText
                android:id="@+id/input_profile_basic_username"
                style="@style/Widget.TermLink.Settings.EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/settings_profile_basic_username_hint"
                android:inputType="textEmailAddress|textNoSuggestions" />

            <TextView
                style="@style/TextAppearance.TermLink.Settings.Label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/settings_profile_basic_password_label" />

            <EditText
                android:id="@+id/input_profile_basic_password"
                style="@style/Widget.TermLink.Settings.EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/settings_profile_basic_password_hint"
                android:inputType="textPassword" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/checkbox_profile_mtls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/sessions_text_primary"
            android:text="@string/settings_profile_mtls_enabled" />

        <TextView
            android:id="@+id/text_profile_mtls_certificate_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/sessions_text_secondary"
            android:text="@string/settings_profile_mtls_status_disabled" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_profile_mtls_choose_certificate"
                style="@style/Widget.TermLink.SettingsButton.Primary"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="@string/settings_profile_mtls_select_certificate" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_profile_mtls_remove_certificate"
                style="@style/Widget.TermLink.SettingsButton.DangerText"
                android:layout_width="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/settings_profile_mtls_remove_certificate"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            style="@style/TextAppearance.TermLink.Settings.Label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/settings_profile_mtls_password_label" />

        <EditText
            android:id="@+id/input_profile_mtls_password"
            style="@style/Widget.TermLink.Settings.EditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/settings_profile_mtls_password_hint"
            android:inputType="textPassword" />

        <TextView
            style="@style/TextAppearance.TermLink.Settings.Label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/settings_profile_allowed_hosts_label" />

        <EditText
            android:id="@+id/input_profile_allowed_hosts"
            style="@style/Widget.TermLink.Settings.EditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/settings_profile_allowed_hosts_hint"
            android:inputType="text" />
    </LinearLayout>
</ScrollView>
