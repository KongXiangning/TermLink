<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sessions_bg"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/settings_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_profiles_title"
        android:textColor="@color/sessions_text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/settings_mtls_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/settings_mtls_status_runtime"
        android:textColor="@color/sessions_text_secondary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/settings_insecure_transport_warning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/sessions_error"
        android:textSize="12sp"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_add_profile"
        style="@style/Widget.TermLink.SettingsButton.Primary"
        android:layout_width="match_parent"
        android:layout_marginTop="12dp"
        android:text="@string/settings_add_profile" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/profiles_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp" />
    </ScrollView>
</LinearLayout>
