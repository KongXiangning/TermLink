<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Debug-only: allow cleartext HTTP for local dev servers, and trust
         user-installed CAs so local HTTPS/mTLS test servers can be validated. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
